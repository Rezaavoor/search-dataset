# =============================================================================
# LLM Provider Configuration
# =============================================================================
# The script auto-detects the provider based on which variables are set.
# Configure EITHER OpenAI OR Azure OpenAI (not both).

# -----------------------------------------------------------------------------
# Option 1: OpenAI
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Option 2: Azure OpenAI (recommended for enterprise)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# Embedding-only providers (for evaluate_search.py)
# =============================================================================
# These are used only for embedding evaluation, not for LLM generation.

# -----------------------------------------------------------------------------
# Option 3: AWS Bedrock (e.g., Cohere Embed v4)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_BEDROCK_REGION=eu-central-1

# =============================================================================
# Azure Document Intelligence (for OCR-based PDF extraction)
# =============================================================================
# Used by ingest_corpus.py --ocr to extract text from PDFs using Azure
# Document Intelligence (prebuilt-layout model) instead of pypdf.
# Pricing: ~$1.50 per 1,000 pages.

# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-region.api.cognitive.microsoft.com
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key
